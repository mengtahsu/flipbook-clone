# DeepSeek API key (required for LLM)
# Get it from: https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-...

# Pexels API key (optional for local dev, REQUIRED for Vercel/production)
# Free: https://www.pexels.com/api/ (200 requests/hour, no credit card)
# Without this key, image search falls back to local DuckDuckGo (Python)
PEXELS_API_KEY=

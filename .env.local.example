# Gemini API key (required for LLM — text breakdown + click vision)
# Free tier, no credit card: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Serper.dev API key (primary image source — real Google Images)
# Free 2,500 queries, no credit card: https://serper.dev
# Without this key, image search falls back to DuckDuckGo, then Pexels.
SERPER_API_KEY=

# Pexels API key (final image fallback)
# Free: https://www.pexels.com/api/ (200 requests/hour, no credit card)
PEXELS_API_KEY=
